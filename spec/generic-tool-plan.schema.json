{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-pattern-labs.dev/glyph/generic-tool-plan.schema.json",
  "title": "Generic Tool Plan Baseline",
  "type": "object",
  "additionalProperties": false,
  "required": ["steps"],
  "properties": {
    "goal": {
      "type": "string"
    },
    "context": {
      "type": "object",
      "additionalProperties": true
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/step"
      }
    }
  },
  "$defs": {
    "step": {
      "oneOf": [
        {
          "$ref": "#/$defs/toolStep"
        },
        {
          "$ref": "#/$defs/repairStep"
        }
      ]
    },
    "toolStep": {
      "type": "object",
      "additionalProperties": false,
      "required": ["op", "args"],
      "properties": {
        "op": {
          "type": "string",
          "pattern": "^[A-Z][A-Z0-9_]*$"
        },
        "args": {
          "type": "object",
          "additionalProperties": true
        },
        "assignTo": {
          "type": "string",
          "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
        }
      }
    },
    "repairStep": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repair"],
      "properties": {
        "repair": {
          "type": "object",
          "additionalProperties": false,
          "required": ["targetVar", "reportVar", "maxIterations", "steps"],
          "properties": {
            "targetVar": {
              "type": "string",
              "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
            },
            "reportVar": {
              "type": "string",
              "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
            },
            "maxIterations": {
              "type": "integer",
              "minimum": 1
            },
            "steps": {
              "type": "array",
              "minItems": 1,
              "items": {
                "$ref": "#/$defs/step"
              }
            }
          }
        }
      }
    }
  }
}
